{
  "name": "chorify",
  "version": "0.1.0",
  "private": true,
  "description": "Chorify — AI video marketing platform (Kuaizi-style blueprint)",
  "packageManager": "pnpm@10.33.2",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "typecheck": "turbo run typecheck",
    "db:generate": "pnpm --filter @chorify/db generate",
    "db:migrate": "pnpm --filter @chorify/db migrate",
    "db:push": "pnpm --filter @chorify/db push",
    "db:seed": "pnpm --filter @chorify/db seed",
    "db:studio": "pnpm --filter @chorify/db studio",
    "infra:up": "docker compose up -d",
    "infra:down": "docker compose down"
  },
  "devDependencies": {
    "turbo": "^2.3.3",
    "typescript": "^5.7.2"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/client",
      "@prisma/engines",
      "prisma",
      "esbuild",
      "sharp",
      "@alicloud/openapi-core"
    ]
  }
}
