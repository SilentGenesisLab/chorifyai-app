MOCK_MODE=true
CORS_ORIGINS=http://localhost:3001,http://127.0.0.1:3001

# Aliyun OSS — real file storage
OSS_PROVIDER=aliyun
ALIYUN_OSS_ENDPOINT=oss-cn-shenzhen.aliyuncs.com
ALIYUN_OSS_BUCKET=chorify-nova
ALIYUN_OSS_ACCESS_KEY_ID=
ALIYUN_OSS_ACCESS_KEY_SECRET=
ALIYUN_OSS_PUBLIC_BASE_URL=https://oss3.sligenai.cn

MAX_UPLOAD_MB=60

# Doubao (ByteDance) speech — TTS + ASR
DOUBAO_TTS_ACCESS_KEY=
DOUBAO_TTS_APP_ID=
DOUBAO_TTS_RESOURCE_ID=seed-tts-2.0
DOUBAO_ASR_API_KEY=
DOUBAO_ASR_RESOURCE_ID=volc.seedasr.auc

# Doubao LLM (火山方舟 Ark) — AI 写文案 / 文本翻译
ARK_API_KEY=
ARK_ENDPOINT=https://ark.cn-beijing.volces.com/api/v3/responses
ARK_MODEL=doubao-seed-2-0-pro-260215

# VoxCPM 语音克隆（自建 GPU 服务，留空则克隆功能禁用）
# 直连: http://127.0.0.1:8190   经 ailab 网关: http://127.0.0.1:8089/tts/voxcpm
VOXCPM_URL=
VOXCPM_TIMEOUT=180
