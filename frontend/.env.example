# ============================================================
# Chorify — shared environment reference
# Copy the values you need into:
#   - apps/web/.env          (Next.js: web + auth backend)
#   - packages/db/.env       (Prisma: DATABASE_URL)
#   - apps/ai-service/.env   (FastAPI: AI service)
# ============================================================

# --- Database (Postgres via docker-compose) ---
DATABASE_URL="postgresql://chorify:chorify@127.0.0.1:5432/chorify?schema=public"

# --- Redis (SMS codes, rate limiting, cache) ---
REDIS_URL="redis://127.0.0.1:6379"

# --- Auth / session ---
# 32+ char random secret used to sign session JWTs (jose). Keep it STABLE so
# existing logins survive restarts/redeploys (changing it invalidates sessions).
JWT_SECRET="change-me-to-a-long-random-string-min-32-chars"
SESSION_TTL_DAYS="30"
# Mark the session cookie Secure (HTTPS-only). Leave "false" for local http
# (localhost / LAN) so the persistent login cookie is actually stored; set
# "true" only when serving over HTTPS.
SESSION_COOKIE_SECURE="false"

# --- SMS provider (login codes) ---
# SMS_PROVIDER: "mock" (logs the code to the server console) | "aliyun"
SMS_PROVIDER="mock"
ALIYUN_SMS_ACCESS_KEY_ID=""
ALIYUN_SMS_ACCESS_KEY_SECRET=""
ALIYUN_SMS_SIGN_NAME=""
ALIYUN_SMS_TEMPLATE_CODE=""

# --- Object storage (Aliyun OSS) ---
# OSS_PROVIDER: "mock" (no-op, returns fake URLs) | "aliyun"
OSS_PROVIDER="mock"
ALIYUN_OSS_REGION=""
ALIYUN_OSS_BUCKET=""
ALIYUN_OSS_ACCESS_KEY_ID=""
ALIYUN_OSS_ACCESS_KEY_SECRET=""
ALIYUN_OSS_PUBLIC_BASE_URL=""

# --- AI service (FastAPI) ---
AI_SERVICE_URL="http://127.0.0.1:8000"

# --- Web app ---
NEXT_PUBLIC_APP_NAME="Chorify"
