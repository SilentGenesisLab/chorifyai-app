# Next.js (web + auth backend). Copy to apps/web/.env
# NOTE: use 127.0.0.1 (not localhost) — on Windows, Node resolves localhost
# to IPv6 ::1 where Docker's published ports don't listen.
DATABASE_URL="postgresql://chorify:chorify@127.0.0.1:5432/chorify?schema=public"
REDIS_URL="redis://127.0.0.1:6379"

JWT_SECRET="change-me-to-a-long-random-string-min-32-chars"
SESSION_TTL_DAYS="30"

# "mock" prints the login code to the server console; "aliyun" uses real SMS.
SMS_PROVIDER="mock"
ALIYUN_SMS_ACCESS_KEY_ID=""
ALIYUN_SMS_ACCESS_KEY_SECRET=""
ALIYUN_SMS_SIGN_NAME=""
ALIYUN_SMS_TEMPLATE_CODE=""

# "mock" returns fake URLs; "aliyun" uploads to OSS.
OSS_PROVIDER="mock"
ALIYUN_OSS_REGION=""
ALIYUN_OSS_BUCKET=""
ALIYUN_OSS_ACCESS_KEY_ID=""
ALIYUN_OSS_ACCESS_KEY_SECRET=""
ALIYUN_OSS_PUBLIC_BASE_URL=""

AI_SERVICE_URL="http://127.0.0.1:8000"
NEXT_PUBLIC_APP_NAME="Chorify"
